    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@sap/ux-specification": "^1.108.0",
    "mbt": "^1.2.0"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      }
