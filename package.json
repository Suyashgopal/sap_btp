{
  "name": "student-management",
  "version": "1.0.0",
  "description": "Student Management System using SAP CAP",
  "main": "index.js",
  "scripts": {
    "start": "cds run",
    "watch": "cds watch",
    "build": "mbt build",
    "deploy": "cf deploy mta_archives/student-management_1.0.0.mtar"
  },
  "dependencies": {
    "@sap/cds": "^6.7.0",
