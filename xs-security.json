{
  "xsappname": "student-management",
  "tenant-mode": "dedicated",
  "description": "Student Management System Security Configuration",
  "scopes": [
    {
      "name": "$XSAPPNAME.StudentManager",
      "description": "Manage students (Create, Read, Update, Delete)"
    },
    {
      "name": "$XSAPPNAME.StudentViewer",
      "description": "View students only (Read only)"
    }
  ],
  "role-templates": [
    {
      "name": "StudentManager",
      "description": "Student Manager Role",
      "scope-references": [
        "$XSAPPNAME.StudentManager"
      ]
    },
    {
      "name": "StudentViewer",
      "description": "Student Viewer Role",
      "scope-references": [
        "$XSAPPNAME.StudentViewer"
      ]
    }
  ],
  "foreign-scope-references": [
    "uaa.user"
  ],
  "oauth2-configuration": {
    "token-validity": 3600,
    "refresh-token-validity": 2592000
  }
}
